<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp"
    tools:context=".LGBTQactivity">

    <TextView
        android:id="@+id/lgbtqTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Proudly You"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#4A148C"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/lgbtqSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your authentic sparks"
        android:textSize="16sp"
        android:textColor="#7B1FA2"
        app:layout_constraintTop_toBottomOf="@id/lgbtqTitle"
        app:layout_constraintStart_toStartOf="@id/lgbtqTitle" />

    <androidx.cardview.widget.CardView
        android:id="@+id/lgbtqCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="70dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="25dp"
        app:cardPreventCornerOverlap="false"
        app:layout_constraintTop_toBottomOf="@id/lgbtqSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/lgbtq_flag_gradient"
            android:padding="50dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/starIcon"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@android:drawable/btn_star_big_on"
                android:layout_marginBottom="16dp"
                android:translationZ="10dp"
                app:tint="#4A148C" />

            <TextView
                android:id="@+id/sparkDisplayTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Celebrate your authenticity!"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:shadowColor="#80000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="6" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/backButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="BACK TO SPARKS"
        android:backgroundTint="#4A148C"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="30dp"
        android:layout_marginHorizontal="40dp" />

</androidx.constraintlayout.widget.ConstraintLayout>